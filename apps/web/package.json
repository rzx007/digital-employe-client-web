{
  "name": "digital-employe-client-electron",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "dev:app": "electron-rebuild -f -w better-sqlite3 && vite --mode electron",
    "build:app": "electron-rebuild -f -w better-sqlite3 && vite build --mode electron && electron-builder",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "config": {
    "electron": {
      "mirror": "https://registry.npmmirror.com/-/binary/electron/"
    }
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.84",
    "@ai-sdk/react": "^3.0.144",
    "@base-ui/react": "^1.3.0",
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@hono/node-server": "^1.19.12",
    "@lexical/react": "^0.42.0",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-query": "^5.96.0",
    "@tanstack/react-router": "^1.168.10",
    "@workspace/ui": "workspace:*",
    "ahooks": "^3.9.7",
    "ai": "^6.0.142",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "lexical": "^0.42.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.7",
    "next-themes": "^0.4.6",
    "ofetch": "^1.5.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.8.0",
    "simple-agents": "workspace:*",
    "sonner": "^2.0.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/router-plugin": "^1.167.12",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "40.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
