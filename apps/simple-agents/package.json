{
  "name": "simple-agents",
  "version": "2.0.0",
  "description": "AI Agent server with session management, file artifacts, and streaming chat",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./app": "./src/app.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "pnpm rebuild better-sqlite3 && tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsup src/index.ts src/app.ts --format esm --clean --out-dir dist && node -e \"require('fs').copyFileSync('src/app.d.ts','dist/app.d.ts')\"",
    "build:watch": "tsup src/index.ts --format esm --clean --out-dir dist --watch",
    "serve": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@ai-sdk/langchain": "^2.0.148",
    "@hono/node-server": "^1.19.12",
    "@langchain/core": "^1.1.38",
    "@langchain/langgraph": "^1.2.6",
    "@langchain/openai": "^1.4.1",
    "@langchain/tavily": "^1.2.0",
    "@scalar/hono-api-reference": "^0.10.5",
    "ai": "^6.0.142",
    "better-sqlite3": "^12.8.0",
    "croner": "^10.0.1",
    "deepagents": "^1.8.8",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "extract-zip": "^2.0.1",
    "hono": "^4.12.9",
    "langchain": "^1.2.39",
    "nanoid": "^5.1.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.10",
    "shx": "^0.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0"
  }
}
