{
  "openapi": "3.1.0",
  "info": {
    "title": "Simple Agents API",
    "description": "AI agent session management API with chat, streaming, and artifact support.\n\n## Streaming Endpoints\n\nTwo streaming modes are available:\n\n- **`/chat/stream`** (AI SDK): Uses `@ai-sdk/langchain` `toUIMessageStream()` to output standard AI SDK `UIMessageChunk` events. Recommended for frontend `useChat` integration.\n- **`/chat/raw-stream`** (Raw): Manually iterates `streamEvents()` outputting custom `StreamEvent` objects. Preserves full LangChain event granularity. Supports disconnect recovery via `/stream/{streamId}`.",
    "version": "2.1.0"
  },
  "servers": [
    {
      "url": "http://localhost:3005",
      "description": "Local development server"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "getServiceInfo",
        "summary": "Get service information",
        "tags": ["Service"],
        "responses": {
          "200": {
            "description": "Service metadata",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ServiceInfo" }
              }
            }
          }
        }
      }
    },
    "/api/sessions": {
      "post": {
        "operationId": "createSession",
        "summary": "Create a new session",
        "tags": ["Sessions"],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateSessionInput" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Session created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Session" }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listSessions",
        "summary": "List all sessions",
        "tags": ["Sessions"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1, "minimum": 1 }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": { "type": "integer", "default": 20, "minimum": 1 }
          },
          {
            "name": "includeArchived",
            "in": "query",
            "schema": { "type": "boolean", "default": false }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated session list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedSessionResult"
                }
              }
            }
          }
        }
      }
    },
    "/api/sessions/{id}": {
      "get": {
        "operationId": "getSession",
        "summary": "Get a session by ID",
        "tags": ["Sessions"],
        "parameters": [{ "$ref": "#/components/parameters/SessionId" }],
        "responses": {
          "200": {
            "description": "Session found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Session" }
              }
            }
          },
          "404": {
            "description": "Session not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateSession",
        "summary": "Update a session",
        "tags": ["Sessions"],
        "parameters": [{ "$ref": "#/components/parameters/SessionId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateSessionInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Session" }
              }
            }
          },
          "404": {
            "description": "Session not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteSession",
        "summary": "Delete a session",
        "tags": ["Sessions"],
        "parameters": [{ "$ref": "#/components/parameters/SessionId" }],
        "responses": {
          "200": {
            "description": "Session deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Session not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/sessions/{id}/messages": {
      "get": {
        "operationId": "getMessages",
        "summary": "List messages in a session",
        "tags": ["Chat"],
        "parameters": [
          { "$ref": "#/components/parameters/SessionId" },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1, "minimum": 1 }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": { "type": "integer", "default": 50, "minimum": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated message list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedMessageResult"
                }
              }
            }
          }
        }
      }
    },
    "/api/sessions/{id}/chat": {
      "post": {
        "operationId": "chat",
        "summary": "Send a message (non-streaming)",
        "description": "Synchronous chat. Sends a user message and waits for the full agent response. Returns content and message ID. Persists both user and assistant messages (including `parts` for assistant).",
        "tags": ["Chat"],
        "parameters": [{ "$ref": "#/components/parameters/SessionId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SendMessageInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ChatResponse" }
              }
            }
          },
          "400": {
            "description": "Invalid request body",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "404": {
            "description": "Session not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "409": {
            "description": "Session has an active stream",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ActiveStreamConflict"
                }
              }
            }
          },
          "500": {
            "description": "Agent invocation failed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/sessions/{id}/chat/stream": {
      "post": {
        "operationId": "chatStream",
        "summary": "Send a message with AI SDK standard streaming",
        "description": "Uses `@ai-sdk/langchain` `toUIMessageStream()` to output standard AI SDK `UIMessageChunk` events via SSE. Compatible with AI SDK `useChat` hook and `ChatTransport`. Automatically persists user message (with `parts`) and assistant response (with full `UIMessage.parts`) to the database when the stream finishes.\n\nEach SSE `data` line is a JSON-encoded `UIMessageChunk` object. The stream ends with `data: [DONE]`.",
        "tags": ["Chat"],
        "parameters": [{ "$ref": "#/components/parameters/SessionId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SendMessageInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SSE stream of AI SDK UIMessageChunk events",
            "content": {
              "text/event-stream": {
                "schema": {
                  "oneOf": [{ "$ref": "#/components/schemas/UIMessageChunk" }],
                  "description": "Each SSE `data` line is a JSON-encoded UIMessageChunk. The stream ends with `data: [DONE]`."
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "404": {
            "description": "Session not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "500": {
            "description": "AI SDK stream failed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/sessions/{id}/chat/raw-stream": {
      "post": {
        "operationId": "chatRawStream",
        "summary": "Send a message with raw LangChain event streaming",
        "description": "Manually iterates `agent.streamEvents()` outputting custom `StreamEvent` objects via SSE. Preserves full LangChain event granularity including `on_chat_model_stream`, `on_tool_start`, `on_tool_end`, `on_chain_start`, and `on_chain_end`.\n\nSupports disconnect recovery via the `/stream/{streamId}` endpoints. Runs as a background task (fire-and-forget) so the agent continues even if the SSE connection drops.",
        "tags": ["Chat"],
        "parameters": [{ "$ref": "#/components/parameters/SessionId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SendMessageInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SSE stream of raw LangChain events",
            "content": {
              "text/event-stream": {
                "schema": {
                  "$ref": "#/components/schemas/StreamEvent",
                  "description": "Each SSE event contains a JSON-encoded StreamEvent in the `data` field."
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "404": {
            "description": "Session not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "409": {
            "description": "Session already has an active stream",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ActiveStreamConflict"
                }
              }
            }
          }
        }
      }
    },
    "/api/sessions/{id}/stream": {
      "get": {
        "operationId": "getStreamStatus",
        "summary": "Get the current stream status for a session",
        "description": "Only applicable to raw-stream sessions. Checks the in-memory stream registry first, then falls back to the database.",
        "tags": ["Streaming"],
        "parameters": [{ "$ref": "#/components/parameters/SessionId" }],
        "responses": {
          "200": {
            "description": "Stream status",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StreamStatus" }
              }
            }
          }
        }
      }
    },
    "/api/sessions/{id}/stream/{streamId}": {
      "get": {
        "operationId": "resumeStream",
        "summary": "Resume or retrieve a raw stream by ID",
        "description": "Only applicable to raw-stream sessions. If the stream is still running, returns an SSE continuation. If completed, returns JSON with the result. Falls back to the database for page-reload recovery.",
        "tags": ["Streaming"],
        "parameters": [
          { "$ref": "#/components/parameters/SessionId" },
          { "$ref": "#/components/parameters/StreamId" }
        ],
        "responses": {
          "200": {
            "description": "Stream result or SSE continuation stream",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StreamResult" }
              },
              "text/event-stream": {
                "schema": {
                  "description": "SSE stream resuming from cached content or live events."
                }
              }
            }
          },
          "404": {
            "description": "Stream not found or expired",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StreamNotFound" }
              }
            }
          }
        }
      }
    },
    "/api/sessions/{id}/stream/{streamId}/cancel": {
      "post": {
        "operationId": "cancelStream",
        "summary": "Cancel an active raw stream",
        "description": "Only applicable to raw-stream sessions. Aborts the background agent task and stops the SSE connection.",
        "tags": ["Streaming"],
        "parameters": [
          { "$ref": "#/components/parameters/SessionId" },
          { "$ref": "#/components/parameters/StreamId" }
        ],
        "responses": {
          "200": {
            "description": "Stream cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "streamId": { "type": "string" }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Stream not found, already completed, or expired",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/sessions/{id}/artifacts": {
      "get": {
        "operationId": "listArtifacts",
        "summary": "List artifacts for a session",
        "tags": ["Artifacts"],
        "parameters": [{ "$ref": "#/components/parameters/SessionId" }],
        "responses": {
          "200": {
            "description": "Artifact list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Artifact" }
                }
              }
            }
          }
        }
      }
    },
    "/api/sessions/{id}/artifacts/{artifactId}": {
      "get": {
        "operationId": "getArtifact",
        "summary": "Download an artifact file",
        "tags": ["Artifacts"],
        "parameters": [
          { "$ref": "#/components/parameters/SessionId" },
          { "$ref": "#/components/parameters/ArtifactId" }
        ],
        "responses": {
          "200": {
            "description": "Artifact file content",
            "content": {
              "*/*": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          },
          "404": {
            "description": "Artifact or file not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteArtifact",
        "summary": "Delete an artifact",
        "tags": ["Artifacts"],
        "parameters": [
          { "$ref": "#/components/parameters/SessionId" },
          { "$ref": "#/components/parameters/ArtifactId" }
        ],
        "responses": {
          "200": {
            "description": "Artifact deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Artifact not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "SessionId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Session ID"
      },
      "StreamId": {
        "name": "streamId",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Stream task ID"
      },
      "ArtifactId": {
        "name": "artifactId",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Artifact ID"
      }
    },
    "schemas": {
      "ServiceInfo": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" },
          "dataDir": { "type": "string" },
          "endpoints": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      },
      "Session": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "metadata": { "type": ["string", "null"] },
          "isArchived": { "type": "boolean" }
        },
        "required": ["id", "title", "createdAt", "updatedAt", "isArchived"]
      },
      "CreateSessionInput": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "metadata": { "type": "object" }
        }
      },
      "UpdateSessionInput": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "metadata": { "type": "object" },
          "isArchived": { "type": "boolean" }
        }
      },
      "Message": {
        "type": "object",
        "description": "A stored message. The `parts` field contains the full AI SDK UIMessage parts as a JSON array (for assistant messages created via the AI SDK stream endpoint). The `content` field is a plain-text fallback.",
        "properties": {
          "id": { "type": "integer" },
          "sessionId": { "type": "string" },
          "role": {
            "type": "string",
            "enum": ["user", "assistant", "system", "tool"]
          },
          "content": {
            "type": ["string", "null"],
            "description": "Plain text content (fallback)"
          },
          "parts": {
            "type": ["string", "null"],
            "description": "JSON-encoded UIMessage parts array. Present for messages created via the AI SDK stream endpoint. Contains text, tool-invocation, tool-result parts etc."
          },
          "toolCalls": {
            "type": ["string", "null"],
            "description": "JSON-encoded tool calls (legacy)"
          },
          "toolResults": {
            "type": ["string", "null"],
            "description": "JSON-encoded tool results (legacy)"
          },
          "tokenCount": { "type": ["integer", "null"] },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "sessionId", "role", "createdAt"]
      },
      "SendMessageInput": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        },
        "required": ["message"]
      },
      "ChatResponse": {
        "type": "object",
        "properties": {
          "content": { "type": ["string", "null"] },
          "messageId": { "type": "integer" }
        }
      },
      "UIMessageChunk": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "const": "start" },
              "messageId": { "type": "string" }
            },
            "required": ["type"]
          },
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "const": "text-start" },
              "id": { "type": "string" }
            },
            "required": ["type", "id"]
          },
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "const": "text-delta" },
              "id": { "type": "string" },
              "delta": { "type": "string" }
            },
            "required": ["type", "id", "delta"]
          },
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "const": "text-end" },
              "id": { "type": "string" }
            },
            "required": ["type", "id"]
          },
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "const": "tool-input-start" },
              "toolCallId": { "type": "string" },
              "toolName": { "type": "string" }
            },
            "required": ["type", "toolCallId", "toolName"]
          },
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "const": "tool-input-delta" },
              "toolCallId": { "type": "string" },
              "inputTextDelta": { "type": "string" }
            },
            "required": ["type", "toolCallId", "inputTextDelta"]
          },
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "const": "tool-input-available" },
              "toolCallId": { "type": "string" },
              "toolName": { "type": "string" },
              "input": {}
            },
            "required": ["type", "toolCallId", "toolName", "input"]
          },
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "const": "tool-output-available" },
              "toolCallId": { "type": "string" },
              "output": {}
            },
            "required": ["type", "toolCallId", "output"]
          },
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "const": "tool-output-error" },
              "toolCallId": { "type": "string" },
              "errorText": { "type": "string" }
            },
            "required": ["type", "toolCallId", "errorText"]
          },
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "const": "finish" },
              "finishReason": { "type": "string" }
            },
            "required": ["type", "finishReason"]
          },
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "const": "error" },
              "errorText": { "type": "string" }
            },
            "required": ["type", "errorText"]
          }
        ],
        "discriminator": { "propertyName": "type" }
      },
      "StreamEvent": {
        "description": "Custom event types emitted by the raw-stream endpoint (manual streamEvents iteration).",
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "const": "stream_start" },
              "streamId": { "type": "string" }
            },
            "required": ["type", "streamId"]
          },
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "const": "chain_start" },
              "name": { "type": "string" },
              "input": {}
            },
            "required": ["type", "name"]
          },
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "const": "chain_end" },
              "name": { "type": "string" },
              "output": {}
            },
            "required": ["type", "name"]
          },
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "const": "token" },
              "content": { "type": "string" }
            },
            "required": ["type", "content"]
          },
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "const": "tool_call_start" },
              "name": { "type": "string" },
              "index": { "type": "integer" },
              "id": { "type": "string" }
            },
            "required": ["type", "name"]
          },
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "const": "tool_call_delta" },
              "args": { "type": "string" },
              "index": { "type": "integer" }
            },
            "required": ["type", "args"]
          },
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "const": "tool_start" },
              "name": { "type": "string" },
              "input": {}
            },
            "required": ["type", "name"]
          },
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "const": "tool_end" },
              "name": { "type": "string" },
              "output": {}
            },
            "required": ["type", "name"]
          },
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "const": "done" },
              "messageId": { "type": "integer" },
